}

fn test_recipe_parse_real() {
    test_group("recipe_parse_real");
    # Test against real zugot recipe if available
    var curl_path = str_from("/home/macro/Repos/zugot/base/curl.cyml");
    if (file_exists(to_cstr(curl_path)) == 1) {
        var recipe = recipe_parse_file(curl_path);
        assert(recipe != 0, "curl parsed");
        assert(str_eq(rc_name(recipe), str_from("curl")), "name=curl");
        assert(str_len(rc_ver(recipe)) > 0, "has version");
        assert(str_eq(rc_license(recipe), str_from("MIT")), "MIT license");
        assert(vec_len(rc_rt_deps(recipe)) > 0, "has runtime deps");
        assert(vec_len(rc_bd_deps(recipe)) > 0, "has build deps");
        # Check glibc is a runtime dep
        var found_glibc = 0;
        var i = 0;
        while (i < vec_len(rc_rt_deps(recipe))) {
            if (str_eq(vec_get(rc_rt_deps(recipe), i), str_from("glibc")) == 1) {
                found_glibc = 1;
            }
            i = i + 1;
        }
        assert(found_glibc, "glibc in runtime deps");
    }
}

