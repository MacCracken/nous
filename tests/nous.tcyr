        if (str_eq(rp_name(vec_get(res, i)), str_from("dup-pkg")) == 1) { cnt = cnt + 1; }
        i = i + 1;
    }
    assert_eq(cnt, 1, "no dup");
    rm_rf(d); rm_rf(c);
}

