fn test_deterministic_order() {
    test_group("deterministic_order");
    var d = mkdir_test();
    var c = mkdir_test();
    write_manifest(d, "zeta-pkg", "native");
    write_manifest(d, "alpha-pkg", "native");
    write_manifest(d, "mid-pkg", "native");
    var r = payload(resolver_new(d, c));
    var list = payload(resolver_list(r));
    var names = vec_new();
    var i = 0;
    while (i < vec_len(list)) {
        var pkg = vec_get(list, i);
        if (ip_src(pkg) == SOURCE_MARKETPLACE) { vec_push(names, ip_name(pkg)); }
        i = i + 1;
    }
    assert_eq(vec_len(names), 3, "3 pkgs");
    assert(str_eq(vec_get(names, 0), str_from("alpha-pkg")), "alpha first");
    assert(str_eq(vec_get(names, 1), str_from("mid-pkg")), "mid second");
    assert(str_eq(vec_get(names, 2), str_from("zeta-pkg")), "zeta third");
    rm_rf(d); rm_rf(c);
}

fn test_multiple() {
    test_group("multiple_pkgs");
    var d = mkdir_test();
    var c = mkdir_test();
    var i = 0;
    while (i < 5) {
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "multi-pkg-");
        str_builder_add_int(sb, i);
        write_manifest(d, to_cstr(str_builder_build(sb)), "native");
        i = i + 1;
    }
    var r = payload(resolver_new(d, c));
    var list = payload(resolver_list(r));
    var cnt = 0;
    i = 0;
    while (i < vec_len(list)) {
        if (str_starts_with(ip_name(vec_get(list, i)), "multi-pkg-") == 1) { cnt = cnt + 1; }
        i = i + 1;
    }
    assert_eq(cnt, 5, "5 pkgs");
    rm_rf(d); rm_rf(c);
}

fn test_is_mkt() {
    test_group("is_mkt");
    var d = mkdir_test();
    var c = mkdir_test();
    write_manifest(d, "my-agent", "native");
    var r = payload(resolver_new(d, c));
    assert_eq(resolver_is_mkt(r, str_from("my-agent")), 1, "is mkt");
    assert_eq(resolver_is_mkt(r, str_from("not-installed")), 0, "not mkt");
    rm_rf(d); rm_rf(c);
}

fn test_errors() {
    test_group("errors");
    var cycle = vec_new();
    vec_push(cycle, str_from("A"));
    vec_push(cycle, str_from("B"));
    vec_push(cycle, str_from("C"));
    vec_push(cycle, str_from("A"));
    assert(str_eq(format_cycle(cycle), str_from("A -> B -> C -> A")), "cycle fmt");
    var e = nous_error_new(ERR_INVALID_PACKAGE_NAME, str_from("bad;pkg"), str_from("invalid character ';'"));
    var msg = nous_error_msg(e);
    assert(str_contains(msg, str_from("bad;pkg")), "has name");
    assert(str_contains(msg, str_from("invalid character")), "has reason");
    var d = mkdir_test();
    var c = mkdir_test();
    var r = payload(resolver_new(d, c));
    assert(is_err_result(resolver_resolve(r, str_from(""))), "empty err");
    assert(is_err_result(resolver_resolve(r, str_from(" leading"))), "ws err");
    assert(is_err_result(resolver_resolve(r, str_from("pkg;rm -rf /"))), "inject err");
    rm_rf(d); rm_rf(c);
}

fn test_json() {
    test_group("json");
    var pkg = resolved_pkg_new(str_from("test-pkg"), str_from("1.2.3"), SOURCE_SYSTEM, str_from("A test"), 4096, vec_new(), 1);
    var json = resolved_to_json(pkg);
    assert(str_contains(json, str_from("test-pkg")), "name");
    assert(str_contains(json, str_from("1.2.3")), "ver");
    assert(str_contains(json, str_from("system")), "src");
    var nb = json_extract_str(json, "name");
    assert(nb != 0, "extracted");
    assert(str_eq(nb, str_from("test-pkg")), "roundtrip");
}

fn test_sysdb_unavailable() {
    test_group("sysdb_unavailable");
    var db = sysdb_make(0);
    assert_eq(sysdb_available(db), 0, "unavailable");
    assert_eq(vec_len(payload(sysdb_search(db, str_from("x")))), 0, "search empty");
    assert_eq(payload(sysdb_is_installed(db, str_from("x"))), 0, "not installed");
    assert_eq(payload(sysdb_get_installed(db, str_from("x"))), 0, "no get");
    assert_eq(vec_len(payload(sysdb_list(db))), 0, "list empty");
    assert_eq(vec_len(payload(sysdb_updates(db))), 0, "no updates");
    assert_eq(payload(sysdb_info(db, str_from("x"))), 0, "no info");
}

fn main() {
    alloc_init();
    args_init();
    test_detect_source();
    test_validate_name();
    test_source_display();
    test_strategy();
    test_registry_new();
    test_registry_scan();
    test_resolver_new();
    test_with_strategy();
    test_resolve_mkt();
    test_resolve_unknown();
    test_only_sys_skips_mkt();
    test_only_mkt();
    test_resolve_flutter();
    test_non_flutter_rejected();
    test_sys_first_fallback();
    test_search_all();
    test_only_unknown();
    test_search_merges();
    test_search_dedup();
    test_list_installed();
    test_deterministic_order();
    test_multiple();
    test_is_mkt();
    test_errors();
    test_json();
    test_sysdb_unavailable();
    return assert_summary();
}

var exit_code = main();
syscall(SYS_EXIT, exit_code);
