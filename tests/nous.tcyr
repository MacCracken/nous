fn test_resolve_mkt() {
    test_group("resolve_mkt");
    var d = mkdir_test();
    var c = mkdir_test();
    write_manifest(d, "test-scanner", "native");
    var r = payload(resolver_new(d, c));
    var res = resolver_resolve(r, str_from("test-scanner"));
    assert(is_ok(res), "ok");
    var pkg = payload(res);
    assert(pkg != 0, "found");
    assert(str_eq(rp_name(pkg), str_from("test-scanner")), "name");
    assert_eq(rp_src(pkg), SOURCE_MARKETPLACE, "src");
    assert_eq(rp_trust(pkg), 1, "trusted");
    rm_rf(d); rm_rf(c);
}

