    var avail = sysdb_available(db);
    assert(avail == 0 || avail == 1, "valid bool");
}

fn test_check_updates_empty() {
    test_group("check_updates_empty");
    var d = mkdir_test();
    var c = mkdir_test();
    var r = payload(resolver_new(d, c));
    var upd = resolver_updates(r);
    assert(is_ok(upd), "updates ok");
    # Can't assert exact count (depends on host), just that it works
    var v = payload(upd);
    assert(vec_len(v) >= 0, "no crash");
    rm_rf(d); rm_rf(c);
}

