fn test_source_serde_roundtrip() {
    test_group("source_serde");
    var sources = vec_new();
    vec_push(sources, SOURCE_SYSTEM);
    vec_push(sources, SOURCE_MARKETPLACE);
    vec_push(sources, SOURCE_FLUTTER_APP);
    vec_push(sources, SOURCE_COMMUNITY);
    vec_push(sources, SOURCE_UNKNOWN);
    var i = 0;
    while (i < vec_len(sources)) {
        var src = vec_get(sources, i);
        var s = source_to_str(src);
        var back = source_from_json(s);
        assert_eq(back, src, "source roundtrip");
        i = i + 1;
    }
}

fn test_strategy_serde_roundtrip() {
    test_group("strategy_serde");
    var strats = vec_new();
    vec_push(strats, strategy_default());
    vec_push(strats, strategy_system_first());
    vec_push(strats, strategy_search_all());
    vec_push(strats, strategy_only(SOURCE_MARKETPLACE));
    vec_push(strats, strategy_only(SOURCE_SYSTEM));
    vec_push(strats, strategy_only(SOURCE_FLUTTER_APP));
    var i = 0;
    while (i < vec_len(strats)) {
        var s = vec_get(strats, i);
        var json = strategy_to_json(s);
        var back = strategy_from_json(json);
        assert(strategy_eq(s, back), "strategy roundtrip");
        i = i + 1;
    }
}

