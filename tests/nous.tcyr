    var res = resolver_resolve_all_with_recipes(r, names);
    assert(is_ok(res), "resolve ok");
    var plan = payload(res);
    var pkgs = pl_packages(plan);
    assert_eq(vec_len(pkgs), 2, "2 packages");
    rm_rf(d); rm_rf(c);
}

fn test_resolution_trace() {
    test_group("resolution_trace");
    var d = mkdir_test();
    var c = mkdir_test();
    write_manifest(d, "traced-pkg", "native");
    var r = payload(resolver_new(d, c));
    r = resolver_with_trace(r);
    resolver_resolve(r, str_from("traced-pkg"));
    var trace = resolver_get_trace(r);
    assert(vec_len(trace) >= 1, "trace has entries");
    # Check trace contains marketplace hit
    var found_hit = 0;
    var i = 0;
    while (i < vec_len(trace)) {
        var entry = vec_get(trace, i);
        if (str_contains(entry, str_from("hit")) == 1) { found_hit = 1; }
        i = i + 1;
    }
    assert(found_hit, "trace shows hit");
    # Resolve a miss
    resolver_clear_trace(r);
    resolver_resolve(r, str_from("nonexistent-pkg"));
    var trace2 = resolver_get_trace(r);
    assert(vec_len(trace2) >= 1, "miss trace has entries");
    var found_miss = 0;
    i = 0;
    while (i < vec_len(trace2)) {
        if (str_contains(vec_get(trace2, i), str_from("miss")) == 1) { found_miss = 1; }
        i = i + 1;
    }
    assert(found_miss, "trace shows miss");
    rm_rf(d); rm_rf(c);
}

fn test_levenshtein() {
    test_group("levenshtein");
    assert_eq(levenshtein(str_from("kitten"), str_from("sitting")), 3, "kitten/sitting");
    assert_eq(levenshtein(str_from(""), str_from("abc")), 3, "empty/abc");
    assert_eq(levenshtein(str_from("abc"), str_from("abc")), 0, "same");
    assert_eq(levenshtein(str_from("nginx"), str_from("ngins")), 1, "nginx/ngins");
    assert_eq(levenshtein(str_from("curl"), str_from("crul")), 2, "curl/crul");
}

fn test_suggestion_engine() {
    test_group("suggestion_engine");
    var d = mkdir_test();
    var c = mkdir_test();
    write_manifest(d, "nginx", "native");
    write_manifest(d, "curl", "native");
    write_manifest(d, "openssl", "native");
    var r = payload(resolver_new(d, c));
    var names = collect_known_names(r);
    assert(vec_len(names) >= 3, "has names");
    var s1 = suggest_package(str_from("nginx"), names);
    assert(s1 != 0, "nginx -> suggestion");
    assert(str_eq(s1, str_from("nginx")), "nginx -> nginx");
    var s2 = suggest_package(str_from("zzzzzzz"), names);
    assert_eq(s2, 0, "no match for zzzzzzz");
    var msg = build_suggestion(str_from("nginx"), s1);
    assert(str_contains(msg, str_from("Did you mean")), "has suggestion text");
    assert(str_contains(msg, str_from("nginx")), "has correct name");
    rm_rf(d); rm_rf(c);
}

fn test_sysdb_unavailable() {
    test_group("sysdb_unavailable");
    var db = sysdb_make(0);
    assert_eq(sysdb_available(db), 0, "unavailable");
    assert_eq(vec_len(payload(sysdb_search(db, str_from("x")))), 0, "search empty");
    assert_eq(payload(sysdb_is_installed(db, str_from("x"))), 0, "not installed");
    assert_eq(payload(sysdb_get_installed(db, str_from("x"))), 0, "no get");
    assert_eq(vec_len(payload(sysdb_list(db))), 0, "list empty");
    assert_eq(vec_len(payload(sysdb_updates(db))), 0, "no updates");
    assert_eq(payload(sysdb_info(db, str_from("x"))), 0, "no info");
}

