        str_from("B"), str_from("MIT"), str_from("x86_64"));
    recipe_set_deps(recipe_b, vec_new(), vec_new());
    map_set(recipes, "dep-b", recipe_b);
    var rdb = recipe_db_new(str_from("/tmp"), recipes, vec_new());
    r = resolver_with_recipes(r, rdb);
    # Resolve with recipe fallback
    var names = vec_new();
