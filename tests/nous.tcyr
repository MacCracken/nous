fn test_search_merges() {
    test_group("search_merges");
    var d = mkdir_test();
    var c = mkdir_test();
    write_manifest(d, "test-tool", "native");
    var r = payload(resolver_new(d, c));
    var sr = payload(resolver_search(r, str_from("test")));
    assert(sr_total(sr) >= 1, "results");
    var found = 0;
    var res = sr_results(sr);
    var i = 0;
    while (i < vec_len(res)) {
        if (str_eq(rp_name(vec_get(res, i)), str_from("test-tool")) == 1) { found = 1; }
        i = i + 1;
    }
    assert(found, "test-tool found");
    rm_rf(d); rm_rf(c);
}

