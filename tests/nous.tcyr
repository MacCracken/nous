# nous test suite — ported from 56 Rust unit tests

include "src/nous.cyr"

var tc = 0;

fn mkdir_test() {
    tc = tc + 1;
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "/tmp/nous-test-");
    str_builder_add_int(sb, sys_getpid());
    str_builder_add_cstr(sb, "-");
    str_builder_add_int(sb, tc);
    var d = str_builder_build(sb);
    mkdir_str(d);
    return d;
}

fn write_manifest(dir, name, runtime) {
    var installed = join_path(dir, str_from("installed"));
    mkdir_str(installed);
    var pd = join_path(installed, str_from(name));
    mkdir_str(pd);
    var mp = join_path(pd, str_from("manifest.json"));
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"agent\":{\"name\":\"");
    str_builder_add_cstr(sb, name);
    str_builder_add_cstr(sb, "\",\"version\":\"1.0.0\",\"description\":\"Test package ");
    str_builder_add_cstr(sb, name);
    str_builder_add_cstr(sb, "\"},\"dependencies\":{},\"runtime\":\"");
    str_builder_add_cstr(sb, runtime);
    str_builder_add_cstr(sb, "\"}");
    var json = str_builder_build(sb);
    file_write_all(to_cstr(mp), to_cstr(json), str_len(json));
}

fn write_manifest_deps(dir, name, runtime, deps_json) {
    var installed = join_path(dir, str_from("installed"));
    mkdir_str(installed);
    var pd = join_path(installed, str_from(name));
    mkdir_str(pd);
    var mp = join_path(pd, str_from("manifest.json"));
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"agent\":{\"name\":\"");
    str_builder_add_cstr(sb, name);
    str_builder_add_cstr(sb, "\",\"version\":\"1.0.0\",");
    str_builder_add_cstr(sb, "\"description\":\"");
    str_builder_add_cstr(sb, name);
    str_builder_add_cstr(sb, "\"},\"dependencies\":{");
    str_builder_add_cstr(sb, deps_json);
    str_builder_add_cstr(sb, "},\"runtime\":\"");
    str_builder_add_cstr(sb, runtime);
    str_builder_add_cstr(sb, "\"}");
    var json = str_builder_build(sb);
    file_write_all(to_cstr(mp), to_cstr(json), str_len(json));
}

fn rm_rf(path) {
    var cp = to_cstr(path);
    if (is_dir(cp) == 1) {
        var e = dir_list(cp);
        var i = 0;
        while (i < vec_len(e)) {
            rm_rf(join_path(path, vec_get(e, i)));
            i = i + 1;
        }
        sys_rmdir(cp);
    } else { sys_unlink(cp); }
}

# ===================================================================

fn test_detect_source() {
    test_group("detect_source");
    assert_eq(detect_source(str_from("acme/scanner")), SOURCE_MARKETPLACE, "slash");
    assert_eq(detect_source(str_from("publisher/agent-name")), SOURCE_MARKETPLACE, "pub/agent");
    assert_eq(detect_source(str_from("com.example.app")), SOURCE_FLUTTER_APP, "com.example");
    assert_eq(detect_source(str_from("myapp.flutter")), SOURCE_FLUTTER_APP, ".flutter");
    assert_eq(detect_source(str_from("org.agnos.files")), SOURCE_FLUTTER_APP, "org.agnos");
    assert_eq(detect_source(str_from("io.flutter.demo")), SOURCE_FLUTTER_APP, "io.flutter");
    assert_eq(detect_source(str_from("nginx")), SOURCE_UNKNOWN, "nginx");
    assert_eq(detect_source(str_from("curl")), SOURCE_UNKNOWN, "curl");
    assert_eq(detect_source(str_from("")), SOURCE_UNKNOWN, "empty");
    assert_eq(detect_source(str_from("a/b/c")), SOURCE_MARKETPLACE, "multi-slash");
    assert_eq(detect_source(str_from("foo.bar")), SOURCE_UNKNOWN, "single-dot");
    assert_eq(detect_source(str_from("my.custom.thing")), SOURCE_UNKNOWN, "non-tld");
}

fn test_validate_name() {
    test_group("validate_name");
    assert(is_ok(validate_package_name(str_from("valid-pkg"))), "valid");
    assert(is_ok(validate_package_name(str_from("publisher/agent"))), "pub/agent");
    assert(is_ok(validate_package_name(str_from("com.example.app"))), "dotted");
    assert(is_ok(validate_package_name(str_from("lib_foo+bar"))), "underscore+plus");
    assert(is_err_result(validate_package_name(str_from(""))), "empty");
    assert(is_err_result(validate_package_name(str_from(" leading"))), "leading ws");
    assert(is_err_result(validate_package_name(str_from("pkg;rm"))), "semicolon");
    assert(is_err_result(validate_package_name(str_from("pkg|bad"))), "pipe");
}

fn test_source_display() {
    test_group("source_display");
    assert(str_eq(source_to_str(SOURCE_SYSTEM), str_from("system")), "system");
    assert(str_eq(source_to_str(SOURCE_MARKETPLACE), str_from("marketplace")), "mkt");
    assert(str_eq(source_to_str(SOURCE_FLUTTER_APP), str_from("flutter-app")), "flutter");
    assert(str_eq(source_to_str(SOURCE_COMMUNITY), str_from("community")), "community");
    assert(str_eq(source_to_str(SOURCE_UNKNOWN), str_from("unknown")), "unknown");
}

fn test_strategy() {
    test_group("strategy");
    assert_eq(st_kind(strategy_default()), STRAT_MARKETPLACE_FIRST, "default");
    assert_eq(st_kind(strategy_system_first()), STRAT_SYSTEM_FIRST, "sys_first");
    var only = strategy_only(SOURCE_SYSTEM);
    assert_eq(st_kind(only), STRAT_ONLY_SOURCE, "only kind");
    assert_eq(st_only(only), SOURCE_SYSTEM, "only target");
    assert(strategy_eq(strategy_default(), strategy_default()), "eq same");
    assert(strategy_eq(strategy_default(), strategy_system_first()) == 0, "neq diff");
    assert(strategy_eq(strategy_only(SOURCE_SYSTEM), strategy_only(SOURCE_MARKETPLACE)) == 0, "neq only");
}

fn test_registry_new() {
    test_group("registry_new");
    var d = mkdir_test();
    assert(is_ok(registry_new(d)), "valid dir");
    assert(is_err_result(registry_new(str_from("/nonexistent/path"))), "bad dir");
    rm_rf(d);
}

fn test_registry_scan() {
    test_group("registry_scan");
    var d = mkdir_test();
    write_manifest(d, "test-scanner", "native");
    var reg = payload(registry_new(d));
    var pkg = registry_get(reg, str_from("test-scanner"));
    assert(pkg != 0, "found");
    assert(str_eq(mpkg_name(pkg), str_from("test-scanner")), "name");
    assert(str_eq(mpkg_version(pkg), str_from("1.0.0")), "version");
    assert(registry_get(reg, str_from("nonexistent")) == 0, "miss");
    assert(vec_len(registry_search(reg, str_from("test"))) >= 1, "search");
    assert_eq(vec_len(registry_list(reg)), 1, "list");
    rm_rf(d);
}

