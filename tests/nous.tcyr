    var jsb = str_builder_new();
    str_builder_add_cstr(jsb, "{\"agent\":{\"name\":\"dep-test\",");
    str_builder_add_cstr(jsb, "\"version\":\"1.0.0\",\"description\":\"test\"},");
    str_builder_add_cstr(jsb, "\"dependencies\":{\"libfoo\":\">=1.0\",");
    str_builder_add_cstr(jsb, "\"libbar\":\">=2.0\"},\"runtime\":\"native\"}");
    var json = to_cstr(str_builder_build(jsb));
    file_write_all(to_cstr(mp), json, strlen(json));
    var reg = payload(registry_new(d));
