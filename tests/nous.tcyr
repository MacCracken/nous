fn test_manifest_serde_roundtrip() {
    test_group("manifest_serde");
    var deps = map_new();
    map_set(deps, "dep-a", str_from(">=1.0"));
    var agent = agent_info_new(str_from("test-agent"), str_from("2.0.0"),
        str_from("A test agent"));
    var m = manifest_new(agent, deps, str_from("native"));
    var json = manifest_to_json(m);
    assert(str_contains(json, str_from("test-agent")), "has name");
    assert(str_contains(json, str_from("2.0.0")), "has version");
    assert(str_contains(json, str_from("dep-a")), "has dep");
    assert(str_contains(json, str_from("native")), "has runtime");
}

fn test_error_kind_serde_roundtrip() {
    test_group("error_kind_serde");
    var e1 = nous_error_new(ERR_COMMAND_EXEC, str_from("apt-cache"), str_from("not found"));
    var j1 = error_kind_to_json(e1);
    var b1 = error_kind_from_json(j1);
    assert_eq(ne_kind(b1), ERR_COMMAND_EXEC, "kind roundtrip");
    assert(str_eq(ne_msg(b1), str_from("apt-cache")), "msg roundtrip");

    var e2 = nous_error_new(ERR_DEPENDENCY_CYCLE, str_from("A -> B -> A"), 0);
    var j2 = error_kind_to_json(e2);
    assert(str_contains(j2, str_from("A -> B -> A")), "cycle in json");

    var e3 = nous_error_new(ERR_VERSION_CONFLICT, str_from("foo"), str_from("conflict"));
    var j3 = error_kind_to_json(e3);
    var b3 = error_kind_from_json(j3);
    assert_eq(ne_kind(b3), ERR_VERSION_CONFLICT, "conflict kind");
    assert(str_eq(ne_msg(b3), str_from("foo")), "conflict msg");
}

fn test_error_display_all_variants() {
    test_group("error_display_all");
    var e1 = nous_error_new(ERR_COMMAND_EXEC, str_from("apt-cache search"), str_from("not found"));
    var m1 = nous_error_msg(e1);
    assert(str_contains(m1, str_from("apt-cache search")), "cmd exec msg");
    assert(str_contains(m1, str_from("not found")), "cmd exec detail");

    var e2 = nous_error_new(ERR_REGISTRY_IO, str_from("/tmp/test"), str_from("permission denied"));
    var m2 = nous_error_msg(e2);
    assert(str_contains(m2, str_from("/tmp/test")), "registry io path");

    var e3 = nous_error_new(ERR_INVALID_MANIFEST, str_from("/tmp/manifest.json"), str_from("invalid json"));
    var m3 = nous_error_msg(e3);
    assert(str_contains(m3, str_from("manifest")), "manifest keyword");

    var e4 = nous_error_new(ERR_INVALID_VERSION_CONSTRAINT, str_from(">>1.0"), str_from("unknown operator >>"));
    var m4 = nous_error_msg(e4);
    assert(str_contains(m4, str_from(">>1.0")), "constraint msg");
    assert(str_contains(m4, str_from("unknown operator")), "constraint detail");
}

fn test_registry_reload() {
    test_group("registry_reload");
    var d = mkdir_test();
    var c = mkdir_test();
    var reg = payload(registry_new(d));
    assert_eq(vec_len(registry_list(reg)), 0, "starts empty");
    write_manifest(d, "late-pkg", "native");
    registry_reload(reg);
    assert_eq(vec_len(registry_list(reg)), 1, "after reload");
    assert(str_eq(mpkg_name(registry_get(reg, str_from("late-pkg"))), str_from("late-pkg")), "found late-pkg");
    rm_rf(d); rm_rf(c);
}

fn test_deps_parsing() {
